    "node": "18.x",
    "yarn": "1.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/postvelocity.git"
  },
  "keywords": [
    "social-media",
    "ai",
    "content-generation",
    "marketing",
    "automation"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}